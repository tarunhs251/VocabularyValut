# Set default behavior for all files
* text=auto

# Kotlin and Java files
*.kt text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.kts text eol=lf

# XML files
*.xml text eol=lf

# Properties files
*.properties text eol=lf
*.gradle.properties text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text eol=lf
README.md merge=union

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.aab binary
*.dex binary

# Gradle files
gradlew text eol=lf
gradlew.bat text eol=crlf
